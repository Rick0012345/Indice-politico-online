generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Politico {
  id             BigInt    @id @db.BigInt
  cpf            String?   @unique @db.VarChar(11)
  nome           String
  nomeCivil      String?   @map("nome_civil")
  siglaPartido   String    @map("sigla_partido") @db.VarChar(50)
  siglaUf        String    @map("sigla_uf") @db.VarChar(2)
  idLegislatura  Int?      @map("id_legislatura") @db.SmallInt
  dataNascimento DateTime? @map("data_nascimento") @db.Date
  dataUltimoStatus DateTime? @map("data_ultimo_status") @db.Date
  sexo           String?   @db.VarChar(1)
  urlFoto        String?   @map("url_foto")
  nomeEleitoral  String?   @map("nome_eleitoral") @db.VarChar(255)
  condicaoEleitoral String? @map("condicao_eleitoral") @db.VarChar(100)
  email          String?   @db.VarChar(100)
  telefone       String?   @db.VarChar(50)
  urlWebsite     String?   @map("url_website") @db.Text
  redesSociais   String?   @map("redes_sociais") @db.Text
  escolaridade   String?   @db.VarChar(100)
  municipioNascimento String? @map("municipio_nascimento") @db.VarChar(100)
  ufNascimento   String?   @map("uf_nascimento") @db.VarChar(2)
  gabineteNome   String?   @map("gabinete_nome") @db.VarChar(50)
  gabinetePredio String?   @map("gabinete_predio") @db.VarChar(20)
  gabineteSala   String?   @map("gabinete_sala") @db.VarChar(20)
  gabineteAndar  String?   @map("gabinete_andar") @db.VarChar(20)
  situacao       String?   @default("Exercício") @db.VarChar(50)
  ativo          Boolean?  @default(true)
  atualizadoEm   DateTime? @default(now()) @map("atualizado_em") @db.Timestamptz(6)

  votos      VotoDeputado[]
  despesas   Despesa[]
  avaliacoes Avaliacao[]
  noticias   NoticiaPolitico[]

  @@map("politicos")
}

model Votacao {
  id              String    @id
  siglaTipo       String?   @map("sigla_tipo") @db.VarChar(20)
  numero          Int?
  ano             Int?
  ementa          String?   @db.Text
  dataVotacao     DateTime? @map("data_hora_votacao") @db.Timestamptz(6)
  resultado       String?   @db.VarChar(255)
  aprovacao       Int?

  votos VotoDeputado[]

  @@map("votacoes")
}

model VotoDeputado {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  votacaoId String @map("votacao_id")
  politicoId BigInt @map("politico_id") @db.BigInt
  voto      String @db.VarChar(50)

  votacao  Votacao  @relation(fields: [votacaoId], references: [id], onDelete: Cascade)
  politico Politico @relation(fields: [politicoId], references: [id], onDelete: Cascade)

  @@unique([votacaoId, politicoId])
  @@index([votacaoId])
  @@index([politicoId])
  @@map("votos_deputados")
}

model Despesa {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  politicoId        BigInt    @map("politico_id") @db.BigInt
  ano               Int       @db.SmallInt
  mes               Int       @db.SmallInt
  tipoDespesa       String    @map("tipo_despesa") @db.VarChar(255)
  codDocumento      String?   @unique @map("cod_documento") @db.VarChar(100)
  cnpjCpfFornecedor String?   @map("cnpj_cpf_fornecedor") @db.VarChar(14)
  nomeFornecedor    String?   @map("nome_fornecedor") @db.VarChar(255)
  tipoDocumento     String?   @map("tipo_documento") @db.VarChar(50)
  dataDocumento     DateTime? @map("data_documento") @db.Date
  numDocumento      String?   @map("num_documento") @db.VarChar(100)
  valorDocumento    Decimal   @map("valor_documento") @db.Decimal(12, 2)
  valorGlosa        Decimal?  @default(0) @map("valor_glosa") @db.Decimal(12, 2)
  valorLiquido      Decimal   @map("valor_liquido") @db.Decimal(12, 2)
  numLote           String?   @map("num_lote") @db.VarChar(50)
  numRessarcimento  String?   @map("num_ressarcimento") @db.VarChar(50)
  parcela           Int?      @default(0) @db.SmallInt
  urlDocumento      String?   @map("url_documento") @db.Text

  politico Politico @relation(fields: [politicoId], references: [id], onDelete: Cascade)

  @@index([politicoId], map: "idx_despesas_politico")
  @@index([cnpjCpfFornecedor], map: "idx_despesas_fornecedor")
  @@index([ano, mes], map: "idx_despesas_data_competencia")
  @@map("despesas")
}

model Avaliacao {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  politicoId    BigInt   @map("politico_id") @db.BigInt
  cpfHash       String   @map("cpf_hash") @db.VarChar(255)
  nota          Int      @db.SmallInt
  comentario    String?  @db.Text
  dataAvaliacao DateTime? @default(now()) @map("data_avaliacao") @db.Timestamptz(6)

  politico Politico @relation(fields: [politicoId], references: [id], onDelete: Cascade)

  @@unique([politicoId, cpfHash])
  @@index([politicoId], map: "idx_avaliacoes_politico")
  @@map("avaliacoes")
}

model NoticiaPolitico {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  politicoId     BigInt    @map("politico_id") @db.BigInt
  titulo         String    @db.Text
  resumo         String?   @db.Text
  url            String    @db.Text
  veiculo        String?   @db.VarChar(255)
  dominio        String?   @db.VarChar(255)
  dataPublicacao DateTime? @map("data_publicacao") @db.Timestamptz(6)
  imagemUrl      String?   @map("imagem_url") @db.Text
  idioma         String?   @db.VarChar(20)
  paisOrigem     String?   @map("pais_origem") @db.VarChar(10)
  fonteColeta    String    @default("gdelt_doc_2") @map("fonte_coleta") @db.VarChar(50)
  periodoTipo    String?   @map("periodo_tipo") @db.VarChar(20)
  janelaConsulta String?   @map("janela_consulta") @db.VarChar(20)
  queryUsada     String?   @map("query_usada") @db.Text
  criadoEm       DateTime? @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm   DateTime? @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  politico Politico @relation(fields: [politicoId], references: [id], onDelete: Cascade)

  @@unique([politicoId, url])
  @@index([politicoId], map: "idx_noticias_politico")
  @@index([dataPublicacao], map: "idx_noticias_data_publicacao")
  @@index([periodoTipo], map: "idx_noticias_periodo_tipo")
  @@map("noticias_politicos")
}
